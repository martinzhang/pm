{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WeCom Bot",
      "type": "debugpy",
      "request": "launch",
      "module": "wecom.bot",
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Flask App",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
